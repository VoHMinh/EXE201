# LastBite API — Mẫu biến môi trường
# Sao chép file này thành .env rồi điền giá trị phù hợp.

# Server
SERVER_PORT=8080

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/lastbite
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=2s

# JWT (HMAC-SHA512 — tạo bằng: openssl rand -base64 64)
JWT_SIGNER_KEY=
JWT_ACCESS_TOKEN_DURATION=900
JWT_REFRESH_TOKEN_DURATION=604800

# CORS (các origin phân tách bằng dấu phẩy)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Cookie xác thực / xác minh email
APP_AUTH_EMAIL_VERIFICATION_URL=http://localhost:8080/api/v1/auth/verify-email-link
APP_AUTH_REFRESH_COOKIE_SECURE=false
APP_AUTH_REFRESH_COOKIE_SAME_SITE=Lax

# Admin seeder
ADMIN_EMAIL=admin@lastbite.com
ADMIN_PASSWORD=
ADMIN_FULL_NAME=LastBite Admin

# JVM trong container
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=60.0 -XX:InitialRAMPercentage=10.0 -Dfile.encoding=UTF-8

# Profile đang dùng
SPRING_PROFILES_ACTIVE=dev
