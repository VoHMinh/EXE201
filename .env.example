# ═══════════════════════════════════════════
#  LastBite API — Environment Template
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# Server
SERVER_PORT=8080

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/lastbite
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# MongoDB
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/lastbite

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=2s

# JWT (HMAC-SHA512 — generate with: openssl rand -base64 64)
JWT_SIGNER_KEY=
JWT_ACCESS_TOKEN_DURATION=1800
JWT_REFRESH_TOKEN_DURATION=604800

# CORS (comma-separated origins)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Active profile
SPRING_PROFILES_ACTIVE=dev
